FROM node:22-bookworm

ARG DEBIAN_MIRROR=https://mirrors.ustc.edu.cn/debian
ARG DEBIAN_SECURITY_MIRROR=https://mirrors.ustc.edu.cn/debian-security
ARG MYSQL_USER=wecom_recorder
ARG MYSQL_PASSWORD=123456
ARG MYSQL_HOST=mysql
ARG MYSQL_PORT=3306
ARG MYSQL_DATABASE=wecom_recorder_dev

RUN printf 'Types: deb\nURIs: %s\nSuites: bookworm bookworm-updates\nComponents: main\nSigned-By: /usr/share/keyrings/debian-archive-keyring.gpg\n\nTypes: deb\nURIs: %s\nSuites: bookworm-security\nComponents: main\nSigned-By: /usr/share/keyrings/debian-archive-keyring.gpg\n' \
    "${DEBIAN_MIRROR}" "${DEBIAN_SECURITY_MIRROR}" \
    > /etc/apt/sources.list.d/debian.sources \
  && apt-get -o Acquire::Retries=3 update \
  && apt-get -o Acquire::Retries=3 install -y --no-install-recommends ffmpeg fonts-droid-fallback \
  && rm -rf /var/lib/apt/lists/* \
  && corepack enable \
  && corepack prepare pnpm@9.15.9 --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml .npmrc ./server/
RUN pnpm --dir server install --frozen-lockfile

COPY . ./server

RUN DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}" pnpm --dir server exec prisma generate \
  && sed -i 's/\r$//' ./server/docker-entrypoint.sh \
  && cp ./server/docker-entrypoint.sh /usr/local/bin/wecom-recorder-entrypoint \
  && chmod +x /usr/local/bin/wecom-recorder-entrypoint \
  && mkdir -p /app/logs /app/server/storage

EXPOSE 8787 9229

ENTRYPOINT ["/usr/local/bin/wecom-recorder-entrypoint"]

CMD ["pnpm", "--dir", "server", "exec", "nodemon", "--legacy-watch", "--watch", ".", "--ext", "js,mjs,cjs", "--ignore", "storage", "--ignore", "logs", "--ignore", "data", "--inspect=0.0.0.0:9229", "index.mjs"]
