PORT=8787
HOST=0.0.0.0
HTTPS_PORT=
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# WeCom user identity. When these are configured, the H5 will open WeCom OAuth
# and use the member name as the uploader name instead of a manually typed name.
WECOM_CORP_ID=
WECOM_APP_SECRET=

# Speech-to-text mode. Leave empty for automatic selection:
# TENCENT_ASR_SECRET_ID + TENCENT_ASR_SECRET_KEY -> tencent_asr,
# OPENAI_API_KEY -> openai, ASR_API_URL -> custom.
# If all are empty, the server uses a local fallback transcript so the app can run.
# Keep recording API transcription disabled unless explicitly needed. Tencent
# Meeting imports should use Tencent Meeting's own transcript.
ASR_API_TRANSCRIPTION_ENABLED=0
ASR_PROVIDER=

# OpenAI transcription.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_URL=https://api.openai.com/v1/audio/transcriptions
OPENAI_TRANSCRIBE_PROMPT=
OPENAI_TRANSCRIBE_RESPONSE_FORMAT=
OPENAI_TRANSCRIBE_LANGUAGE=zh

# Optional. Use this when the server does not have ffmpeg in PATH.
FFMPEG_PATH=

# Tencent Cloud ASR file recognition.
# Tencent Cloud requires both SecretId and SecretKey. The SecretId usually starts with AKID.
# ASR_PROVIDER=tencent_asr
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=
TENCENT_ASR_ENDPOINT=asr.tencentcloudapi.com
TENCENT_ASR_REGION=ap-shanghai
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh_en
TENCENT_ASR_RES_TEXT_FORMAT=3
TENCENT_ASR_SPEAKER_DIARIZATION=1
TENCENT_ASR_SPEAKER_NUMBER=0
TENCENT_ASR_CONVERT_NUM_MODE=1
TENCENT_ASR_ENABLE_HOTWORDS=1
TENCENT_ASR_HOTWORDS=Great Agent OS,Agent OS,硅基画像,硅基人,数据基座,地产投拓,客群画像,原生研判,项目研判,OCEAN,DeepSeek,灵宝,画布,建发,保利,小红书,抖音,方案A,方案B,竖向体量,建筑开发链路,生图,生文,分镜,复盘,CAD,AI
TENCENT_ASR_PROJECT_HOTWORDS=
TENCENT_ASR_PREPROCESS_AUDIO=1
TENCENT_ASR_AUDIO_NORMALIZE=1
TENCENT_ASR_AUDIO_DENOISE=0
TENCENT_ASR_SENTENCE_ENGINE_TYPE=16k_zh_en
TENCENT_ASR_SENTENCE_SUB_SERVICE_TYPE=2
TENCENT_ASR_VOICE_FAST_FALLBACK=1
TENCENT_ASR_CHUNK_SECONDS=1200
TENCENT_ASR_CHUNK_OVERLAP_SECONDS=3
TENCENT_ASR_CHUNK_BITRATE=32k
TENCENT_ASR_MAX_BYTES=5242880
TENCENT_ASR_POLL_INTERVAL_MS=1000
TENCENT_ASR_TIMEOUT_MS=900000

# Tencent Meeting cloud recording import. The app keeps ASR API transcription off,
# then imports Tencent Meeting cloud recordings and their built-in transcripts.
TENCENT_MEETING_CLOUD_LOOKBACK_DAYS=7
TENCENT_MEETING_CLOUD_DISCOVERY_INTERVAL_MS=600000
TENCENT_MEETING_CLOUD_DISCOVERY_PAGE_SIZE=20
TENCENT_MEETING_CLOUD_DISCOVERY_MAX_PAGES=8
TENCENT_MEETING_TRANSCRIPT_MAX_PIDS=200
TENCENT_MEETING_TRANSCRIPT_DETAIL_LIMIT=50

# Custom ASR API. The server posts multipart/form-data with the audio file.
# ASR_PROVIDER=custom
ASR_API_URL=
ASR_API_KEY=
ASR_FILE_FIELD=file
ASR_LANGUAGE=auto

# Backward-compatible custom ASR names used by earlier versions.
TRANSCRIBE_API_URL=
TRANSCRIBE_API_KEY=

# Optional LLM question answering and meeting outlines over the transcript.
# If empty, questions use local transcript matching and still return a jump time.
# For DeepSeek V4-Pro, set LLM_PROVIDER=deepseek and LLM_MODEL=deepseek-v4-pro.
LLM_PROVIDER=
LLM_API_URL=
LLM_API_KEY=
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT_MS=60000
LLM_MAX_COMPLETION_TOKENS=8192
LLM_TEMPERATURE=0.25
DEEPSEEK_THINKING=enabled
DEEPSEEK_REASONING_EFFORT=high
LLM_TOOL_ROUNDS=4

# Qwen-TTS answer read-aloud.
# Use a DashScope/Bailian API key. Workspace endpoint is optional; if your key
# belongs to a Bailian workspace, fill QWEN_TTS_WORKSPACE_ID or QWEN_TTS_ENDPOINT.
DASHSCOPE_API_KEY=
QWEN_TTS_API_KEY=
QWEN_TTS_WORKSPACE_ID=
QWEN_TTS_ENDPOINT=
QWEN_TTS_REGION=cn-beijing
QWEN_TTS_MODEL=qwen-tts
QWEN_TTS_VOICE=Cherry

# Production suggestion:
# AUDIO_STORAGE_PROVIDER=oss
# DATABASE_URL=mysql://user:password@host:3306/wecom_recorder
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=wecom_recorder

# Stored recordings are normalized to MP3, and transcripts are written to TXT.
STORAGE_MP3_BITRATE=96k
STORAGE_MP3_SAMPLE_RATE=16000

