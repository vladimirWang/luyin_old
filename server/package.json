{
  "name": "wecom-recorder-h5",
  "version": "1.0.0",
  "description": "Enterprise WeChat H5 recorder with MP3 storage, TXT transcripts, Tencent ASR and recording QA.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../.env.dev nodemon index.mjs",
    "start:prod": "node index.mjs",
    "migrate:dev": "dotenv -e ../.env.dev -- prisma migrate dev",
    "generate:dev": "dotenv -e ../.env.dev -- prisma generate dev"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "pdfkit": "^0.19.1",
    "prisma": "^7.8.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14"
  }
}
